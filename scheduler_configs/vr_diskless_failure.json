{
  "num_servers": 3,
  "num_runs": 50000,
  "max_iterations": 5000,
  "strict_timers": true,
  "events": {
      "t1": { "allow_timer": [1, "timeout"] },
      "crash1": { "crash": 1 },
      "recover1": { "recover": 1 },
      "crash2": { "crash": 2 },
      "recover2": { "recover": 2 },
      "w1": { "write": [0, "key1", "val1"] },
      "w2": { "write": [0, "key1", "val2"] },
      "r1": { "read": [0, "key1"] },
      "r2": { "read": [1, "key1"] },
      "r3": { "read": [2, "key1"] },
      "r4": { "read": [1, "key1"] }
  },
  "dependencies": [
      ["t1", "crash1"],
      ["crash1", "recover1"],
      ["t1", "crash2"],
      ["crash2", "recover2"],
      ["recover1", "w1"],
      ["recover2", "w1"],
      ["w1", "w2"],
      ["w2", "r1"],
      ["w2", "r2"],
      ["w2", "r3"],
      ["w2", "r4"]
  ]
}