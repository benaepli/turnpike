{
  "num_servers": 3,
  "num_runs": 2000000,
  "max_iterations": 5000,
  "strict_timers": true,
  "events": {
    "w1": { "write": [0, "x", "1"] },
    "allow_t1": { "allow_timer": [1, "timeout"] },
    "crash1": { "crash": 1 },
    "recover1": { "recover": 1 },
    "crash2": { "crash": 2 },
    "recover2": { "recover": 2 },
    "p1": { "partition": { "type": "isolate_one", "node": 1 } },
    "w2": { "write": [0, "x", "2"] },
    "h1": "heal",
    "r1": { "read": [0, "x"] },
    "r2": { "read": [1, "x"] },
    "r3": { "read": [2, "x"] }
  },
  "dependencies": [
    ["w1", "allow_t1"],
    ["allow_t1", "crash1"],
    ["crash1", "recover1"],
    ["recover1", "crash2"],
    ["crash2", "recover2"],
    ["recover2", "p1"],
    ["p1", "w2"],
    ["w2", "h1"],
    ["h1", "r1"],
    ["h1", "r2"],
    ["h1", "r3"]
  ]
}
